{
    "compilerOptions": {
        "target": "ES2023",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "strict": true,
        "noEmit": true,
        "allowImportingTsExtensions": true,
        "erasableSyntaxOnly": true,
        "skipLibCheck": true,
        "types": ["node"]
    },
    "include": ["src/**/*.ts", "tools/**/*.ts", "api/**/*.ts"]
}
