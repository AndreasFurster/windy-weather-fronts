{
    "name": "windy-weather-fronts-server",
    "version": "1.0.0",
    "description": "Backend that periodically collects weather front data from multiple sources and serves it as GeoJSON for the windy-plugin-weather-fronts plugin",
    "type": "module",
    "private": true,
    "engines": {
        "node": ">=20"
    },
    "scripts": {
        "start": "tsx src/index.ts",
        "dev": "tsx watch src/index.ts",
        "calibrate": "tsx tools/calibrate.ts",
        "extract-preview": "tsx tools/extract-preview.ts"
    },
    "dependencies": {
        "@vercel/blob": "^2.6.1",
        "express": "^4.21.2",
        "node-html-parser": "^9.0.0",
        "omggif": "^1.0.10",
        "tsx": "^4.23.0"
    },
    "devDependencies": {
        "@types/express": "^4.17.21",
        "@types/node": "^24.0.0",
        "@vercel/node": "^5.8.22",
        "typescript": "^5.6.0"
    }
}
